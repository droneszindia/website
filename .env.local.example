# --- Email (Resend) ---
# Lead emails send via Resend. If RESEND_API_KEY is unset, submissions are logged
# server-side instead of emailed (no throw) so local dev works without a key.
RESEND_API_KEY=
# Verified sender the client controls, e.g. "DronesZ <enquiry@dronesz.in>".
# Unset → falls back to Resend's shared onboarding@resend.dev (fine for testing only).
RESEND_FROM=
# Recipient for lead notifications. Unset → falls back to CONTACT.email in data/site.ts.
CONTACT_TO_EMAIL=

# --- File storage (Vercel Blob) ---
# Large custom-build files (> 4 MB) upload to public Blob and are emailed as an
# unguessable link. Auto-injected on Vercel when a Blob store is connected; for local
# dev run `vercel env pull .env.local` to fetch it.
BLOB_READ_WRITE_TOKEN=

# --- Abuse controls ---
# Max form submissions per IP per 15-minute window.
RATE_LIMIT_MAX=5
