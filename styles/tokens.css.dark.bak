/* Design tokens — DronesZ cinematic. OKLCH throughout. Values refined by the /design brief before Phase 6. */
@theme {
  /* ---- Color: dark cinematic canvas, white type, single red accent ---- */
  --color-canvas: oklch(14% 0.012 268);      /* near-black base, faint cool cast */
  --color-canvas-deep: oklch(10% 0.01 268);  /* deepest wells / footer */
  --color-surface: oklch(20% 0.015 268);      /* raised cards */
  --color-surface-hi: oklch(26% 0.016 268);   /* hover/elevated */
  --color-line: oklch(32% 0.012 268);         /* hairline borders */

  --color-white: oklch(97% 0 0);              /* primary type */
  --color-muted: oklch(72% 0.008 268);        /* secondary type */
  --color-faint: oklch(55% 0.01 268);         /* tertiary / captions */

  --color-brand-red: oklch(58% 0.214 27);     /* brand accent, tuned for AA on dark */
  --color-brand-red-hi: oklch(66% 0.224 27);  /* hover / active */
  --color-brand-red-dim: oklch(46% 0.16 27);  /* pressed / subtle fills */

  /* light "breather" sections */
  --color-breather: oklch(96% 0.004 268);
  --color-breather-ink: oklch(20% 0.015 268);

  /* ---- Type: fluid clamp scale ---- */
  --font-sans: var(--font-inter), ui-sans-serif, system-ui, sans-serif;
  --font-display: var(--font-display), var(--font-inter), ui-sans-serif, sans-serif;

  --text-xs: clamp(0.75rem, 0.72rem + 0.15vw, 0.85rem);
  --text-sm: clamp(0.875rem, 0.84rem + 0.18vw, 0.95rem);
  --text-base: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
  --text-lg: clamp(1.2rem, 1.1rem + 0.5vw, 1.5rem);
  --text-xl: clamp(1.6rem, 1.3rem + 1.4vw, 2.4rem);
  --text-2xl: clamp(2.2rem, 1.6rem + 2.8vw, 4rem);
  --text-hero: clamp(2.8rem, 1rem + 8vw, 9rem);

  /* ---- Spacing rhythm ---- */
  --space-1: 0.5rem;
  --space-2: 1rem;
  --space-3: 1.75rem;
  --space-4: 3rem;
  --space-section: clamp(5rem, 3rem + 8vw, 12rem);
  --space-gutter: clamp(1.25rem, 0.5rem + 3vw, 4rem);

  /* ---- Motion ---- */
  --duration-fast: 160ms;
  --duration-normal: 320ms;
  --duration-slow: 640ms;
  --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-in-out-cubic: cubic-bezier(0.65, 0, 0.35, 1);

  /* ---- Radii ---- */
  --radius-sm: 0.375rem;
  --radius-md: 0.75rem;
  --radius-lg: 1.25rem;
}
