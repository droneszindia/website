.hero {
  position: relative;
  height: 100vh;
  width: 100%;
  overflow: hidden;
  background: radial-gradient(
    120% 80% at 50% 18%,
    oklch(20% 0.02 268) 0%,
    var(--color-canvas) 55%,
    var(--color-canvas-deep) 100%
  );
}

.hero-stage {
  position: absolute;
  inset: 0;
}

/* On desktop the drone lives in the right half so it clears the headline. */
@media (min-width: 769px) {
  .hero-stage {
    left: 34%;
  }
}

.hero-stage canvas {
  touch-action: none; /* let OrbitControls own drag gestures */
}

.hero-fallback {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
}

/* Tagline overlaid on the stage — does not capture pointer so the 3D drag stays live. */
.hero-copy {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-inline: var(--space-gutter);
  pointer-events: none;
}

.hero-eyebrow {
  font-size: var(--text-sm);
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--color-brand-red-hi);
  margin-bottom: var(--space-2);
}

.hero-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: var(--text-hero);
  line-height: 0.94;
  max-width: 16ch;
}

.hero-title .accent {
  color: var(--color-brand-red);
}

.hero-sub {
  margin-top: var(--space-3);
  max-width: 42ch;
  color: var(--color-muted);
  font-size: var(--text-lg);
}

.hero-cue {
  position: absolute;
  bottom: var(--space-4);
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--text-xs);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-faint);
}

.hero-cue::after {
  content: "";
  width: 1px;
  height: 2.5rem;
  background: linear-gradient(var(--color-brand-red), transparent);
}

@media (max-width: 768px) {
  .hero-copy {
    justify-content: flex-end;
    padding-bottom: 22vh;
  }
}
